# Dynamic sitemap from Netlify Function
/sitemap.xml  /.netlify/functions/sitemap  200

# OG image generation (must be before generic /api/* catch-all)
/api/og-image/*  /.netlify/functions/og-image  200

# API calls → Netlify Functions
/api/*  /.netlify/functions/:splat  200

# Plausible Analytics proxy (first-party paths — must be before SPA catch-all)
/app-assets/js/script.js  https://plausible.io/js/pa-FKdcykjvEN6q_wMdvAIZa.js  200
/app-assets/api/event     https://plausible.io/api/event  200

# Strip trailing slashes sitewide (301). Matches /path/ but not root /.
# 301! forces redirect even when a directory index.html exists.
# Requires pretty_urls = false in netlify.toml (otherwise Netlify loops).
/*/  /:splat  301!

# SPA routing - serve index.html for all other routes
/*    /index.html   200
