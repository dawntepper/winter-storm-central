# Supabase Configuration
# Get these from Supabase → Project Settings → API.
# Used by the client for magic-link auth + cloud-synced saved locations.
# Magic link also requires Supabase → Authentication → URL Configuration:
#   Site URL = your origin (e.g. http://localhost:5173 in dev)
#   Redirect URLs must include  <origin>/auth/callback
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe Configuration (for payments)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Optional: Analytics
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# ============================================
# Storm Admin (Supabase + Netlify build hook)
# ============================================

# Admin password for /admin/storms. ADMIN_PASSWORD (functions) and VITE_ADMIN_PASSWORD
# (client build) MUST be identical or login/save will fail with 401.
VITE_ADMIN_PASSWORD=your-admin-password-here
ADMIN_PASSWORD=your-admin-password-here

# Netlify build hook — triggered when a storm is published/archived from admin.
# Create in Netlify → Site configuration → Build & deploy → Build hooks.
VITE_NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/your-hook-id
NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/your-hook-id

# ============================================
# Weather Alert Email Integration
# Required for the process-weather-alerts function
# ============================================

# Resend API key (email delivery)
# Get from: https://resend.com/api-keys
# Domain must be verified in Resend dashboard (DNS records in Netlify)
RESEND_API_KEY=re_your-resend-api-key-here

# Optional: sender address (default: StormTracking.io <alerts@stormtracking.io>)
# RESEND_FROM=StormTracking.io <alerts@stormtracking.io>

# Supabase service role (server-side only — storm-admin-api, alert functions, prerender, db seeds)
# Netlify checklist:
#   1. Site configuration → Environment variables
#   2. Add SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
#      (aliases also accepted: SUPABASE_SERVICE_KEY_ROLE, SUPABASE_SERVICE_KEY)
#   3. Scope: Functions (or All scopes) — Build-only vars are NOT visible to functions
#   4. Redeploy after saving (Deploys → Trigger deploy)
# Local dev: copy to .env and run `netlify dev` (not `npm run dev` alone)
# Seed scripts: npm run db:seed:locations — needs the service_role JWT (long eyJ… string), NOT anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Location catalog seed scripts (scripts/db/seed-*.js) — service role only, never VITE_*
# Requires counties/cities/city_counties/zip_locations tables (see supabase/migrations/004_locations_catalog.sql)

# Kit (formerly ConvertKit) API v4 key
# Get from: https://app.kit.com/account/edit → API
# Either CONVERTKIT_API_KEY or KIT_API_KEY will work (CONVERTKIT_API_KEY takes priority)
CONVERTKIT_API_KEY=your-kit-api-key-here
KIT_API_KEY=your-kit-api-key-here

# Optional: prefix for state-based tags in Kit (default: "location-")
KIT_STATE_TAG_PREFIX=location-

# Optional: custom field key for subscriber zip codes (default: "zip_code")
KIT_ZIP_FIELD_KEY=zip_code

# Optional: secret token for manual HTTP trigger authentication
ALERT_PROCESS_SECRET=your-secret-token-here
